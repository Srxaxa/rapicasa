---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import WhatsappBoton from '../components/WhatsappBoton.astro'
---

<Layout
    title="Contacto — Rapicasa | Agenda tu Cita en Pereira"
    description="Contáctanos y agenda una cita para construir tu casa prefabricada en Pereira, Dosquebradas y Risaralda. Te respondemos rápido por WhatsApp."
>
    <Nav />

    <section id="contacto-hero">
        <p class="seccion-tag seccion-tag-centro">Hablemos de tu proyecto</p>
        <h1 class="contacto-titulo">Agenda tu cita y construye tu casa propia</h1>
        <p class="contacto-intro">
            Cuéntanos sobre tu lote y tus necesidades. Te contactaremos lo más pronto posible para asesorarte sin compromiso.
        </p>
    </section>

    <section id="contacto-contenido">
        <div class="contacto-grid">

            <!-- Formulario -->
            <div class="contacto-form-wrap">
                <h2>Cuéntanos sobre tu proyecto</h2>
                <form id="form-contacto" class="contacto-form">
                    <div class="campo">
                        <label for="nombre">Nombre completo *</label>
                        <input type="text" id="nombre" required />
                    </div>

                    <div class="campo">
                        <label for="telefono">Teléfono / WhatsApp *</label>
                        <input type="tel" id="telefono" required />
                    </div>

                    <div class="campo">
                        <label for="ciudad">Ciudad / Municipio *</label>
                        <select id="ciudad" required>
                            <option value="">Selecciona una opción</option>
                            <option value="pereira">Pereira</option>
                            <option value="dosquebradas">Dosquebradas</option>
                            <option value="otro-risaralda">Otro municipio de Risaralda</option>
                            <option value="otro-eje">Otro municipio del Eje Cafetero</option>
                        </select>
                    </div>

                    <div class="campo">
                        <label for="lote">¿Ya cuentas con el lote para construir? *</label>
                        <select id="lote" required>
                            <option value="">Selecciona una opción</option>
                            <option value="si">Sí, ya tengo el lote</option>
                            <option value="no">No, todavía no</option>
                        </select>
                    </div>

                    <div class="campo">
                        <label for="mensaje">Cuéntanos un poco más</label>
                        <textarea id="mensaje" rows="4" placeholder="Tamaño aproximado, número de habitaciones, presupuesto estimado..."></textarea>
                    </div>

                    <button type="submit" id="btn-enviar" class="btn-principal btn-full">
                        Enviar solicitud
                    </button>
                    <p id="form-status" class="form-status"></p>
                </form>
            </div>

            <!-- Info de contacto -->
            <div class="contacto-info">
                <div class="info-card">
                    <span class="info-icono">📍</span>
                    <h3>Dirección</h3>
                    <p>[Dirección física de la oficina — Pereira, Risaralda]</p>
                </div>

                <div class="info-card">
                    <span class="info-icono">📞</span>
                    <h3>Teléfono / WhatsApp</h3>
                    <p>+57 301 357 2990</p>
                </div>

                <div class="info-card">
                    <span class="info-icono">🌐</span>
                    <h3>Zona de cobertura</h3>
                    <p>Pereira, Dosquebradas, Risaralda y Eje Cafetero</p>
                </div>

                <a href="https://wa.me/573013572990?text=Hola%2C%20me%20interesa%20información%20sobre%20casas%20prefabricadas%20Rapicasa" target="_blank" rel="noopener" class="btn-whatsapp-grande">
                    💬 Escríbenos directo por WhatsApp
                </a>
            </div>

        </div>
    </section>

    <!-- Mapa -->
    <section id="mapa-seccion">
        <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d127360.6!2d-75.696!3d4.8133!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNMKwNDgnNDcuOSJOIDc1wrA0MSc0NS42Ilc!5e0!3m2!1ses!2sco!4v1700000000000"
            width="100%"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Rapicasa en Pereira"
        ></iframe>
    </section>

    <WhatsappBoton />
</Layout>

<script>
    const form = document.getElementById("form-contacto") as HTMLFormElement
    const btnEnviar = document.getElementById("btn-enviar") as HTMLButtonElement
    const status = document.getElementById("form-status") as HTMLParagraphElement

    form?.addEventListener("submit", async (e) => {
        e.preventDefault()

        const nombre = (document.getElementById("nombre") as HTMLInputElement).value
        const telefono = (document.getElementById("telefono") as HTMLInputElement).value
        const ciudad = (document.getElementById("ciudad") as HTMLSelectElement).value
        const lote = (document.getElementById("lote") as HTMLSelectElement).value
        const mensaje = (document.getElementById("mensaje") as HTMLTextAreaElement).value

        btnEnviar.disabled = true
        btnEnviar.textContent = "Enviando..."

        try {
            const response = await fetch("https://formspree.io/f/xxxxxxxx", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ nombre, telefono, ciudad, lote, mensaje })
            })

            if (response.ok) {
                status.textContent = "¡Solicitud enviada! Te contactaremos pronto."
                status.style.color = "#1b9c63"
                form.reset()
            } else {
                status.textContent = "Hubo un error. Intenta de nuevo o escríbenos por WhatsApp."
                status.style.color = "#b91c1c"
            }
        } catch (error) {
            status.textContent = "Error de conexión. Intenta de nuevo."
            status.style.color = "#b91c1c"
        } finally {
            btnEnviar.disabled = false
            btnEnviar.textContent = "Enviar solicitud"
        }
    })
</script>

<style>
    #contacto-hero {
        padding: 140px 60px 50px;
        text-align: center;
        background: var(--gris-claro);
    }

    .seccion-tag { color: var(--verde); font-weight: 700; font-size: 0.85rem; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 14px; }
    .seccion-tag-centro { text-align: center; }

    .contacto-titulo {
        font-family: var(--fuente-titulo);
        font-size: clamp(2rem, 4vw, 2.8rem);
        color: var(--azul-petroleo);
        margin-bottom: 20px;
        max-width: 700px;
        margin-left: auto; margin-right: auto;
    }

    .contacto-intro {
        max-width: 560px;
        margin: 0 auto;
        color: var(--gris-medio);
        line-height: 1.7;
    }

    #contacto-contenido { padding: 80px 60px; }

    .contacto-grid {
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 60px;
        max-width: 1100px;
        margin: 0 auto;
    }

    .contacto-form-wrap h2 {
        font-family: var(--fuente-titulo);
        font-size: 1.4rem;
        color: var(--azul-petroleo);
        margin-bottom: 28px;
    }

    .campo { margin-bottom: 20px; }

    .campo label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--texto);
        margin-bottom: 8px;
    }

    .campo input, .campo select, .campo textarea {
        width: 100%;
        padding: 13px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        font-family: var(--fuente-cuerpo);
        transition: border-color 0.3s ease;
    }

    .campo input:focus, .campo select:focus, .campo textarea:focus {
        outline: none;
        border-color: var(--verde);
    }

    .campo textarea { resize: vertical; }

    .btn-principal {
        background: var(--verde);
        color: white;
        padding: 16px 34px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-principal:hover { background: var(--verde-oscuro); }
    .btn-full { width: 100%; }

    .form-status { margin-top: 14px; font-size: 0.88rem; min-height: 20px; }

    .contacto-info { display: flex; flex-direction: column; gap: 20px; }

    .info-card {
        background: var(--gris-claro);
        padding: 24px;
        border-radius: 14px;
    }

    .info-icono { font-size: 1.6rem; display: block; margin-bottom: 10px; }

    .info-card h3 {
        font-family: var(--fuente-titulo);
        font-size: 1rem;
        color: var(--azul-petroleo);
        margin-bottom: 6px;
    }

    .info-card p { color: var(--gris-medio); font-size: 0.9rem; }

    .btn-whatsapp-grande {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background: #25D366;
        color: white;
        padding: 18px;
        border-radius: 12px;
        font-weight: 600;
        text-align: center;
        transition: background 0.3s ease;
    }

    .btn-whatsapp-grande:hover { background: #1da851; }

    #mapa-seccion { line-height: 0; }
    #mapa-seccion iframe { display: block; }

    @media (max-width: 900px) {
        #contacto-hero { padding: 110px 24px 40px; }
        #contacto-contenido { padding: 50px 24px; }
        .contacto-grid { grid-template-columns: 1fr; gap: 40px; }
    }
</style>